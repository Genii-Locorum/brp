<section class="actor tab effects {{tab.cssClass}}" data-group="primary" data-tab="effects">

    <div class="effects-grid">
      <div class="diff-label left">{{localize 'BRP.sourceItem'}}</div>
      <div class="diff-label centre">{{localize 'BRP.effect'}}</div>
      <div class="diff-label centre">{{localize 'BRP.amount'}}</div>
      <div class="diff-label centre">{{localize 'BRP.active'}}</div>
    </div>

    <ol class="gr-list">
    {{#each effects as |effect|}}
      <li class="item item-edit effects-grid" data-item-id = "{{effect.id}}" data-document-class="Item">
        <div class="effect-source left rollable" data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'BRP.sourceItem')}}">{{effect.sourceName}}</div>
        <div class="centre truncate" data-tooltip="{{effect.name}}">{{effect.name}}</div>
        <div class="centre">{{effect.value}}</div>
        {{#if effect.isActive}}
        <div class="centre" data-tooltip="{{localize 'BRP.active'}}">
          <a class="mediumIcon"><i class="item-control fas fa-person-rays"></i></a>
        </div>
        {{else}}
        <div class="centre" data-tooltip="{{localize 'BRP.inactive'}}">
          <a class="mediumIcon fade"><i class="item-control fas fa-person-rays"></i></a>
        </div>
        {{/if}}
      </li>
    {{/each}}
    </ol>
</section>