<section class="actor tab combat {{tab.cssClass}}" data-group="primary" data-tab="combat">
  <section>
    <div class=" weapon-tab-grid">
      <div class="diff-label ">{{ localize 'BRP.weapon'}}</div>
      <div class="diff-label centre" data-tooltip="{{localize 'BRP.scoreIncHint'}}">{{ localize 'BRP.chance'}}</div>
      <div class="diff-label centre">{{ localize 'BRP.damage'}}</div>
      <div class="diff-label centre" data-tooltip="{{ localize 'BRP.dmgBonus'}}">{{ localize 'BRP.dmgBonusInitials'}}</div>
      <div class="diff-label centre">{{ localize 'BRP.range'}}</div>
      <div class="diff-label centre">{{ localize 'BRP.att'}}</div>
      <div class="diff-label centre" data-tooltip="{{localize 'BRP.handCrewHint'}}">{{ localize 'BRP.handCrew'}}</div>
      <div class="diff-label centre" style="grid-column: 8 / span 2;"
        data-tooltip="{{ localize 'BRP.ppStoreHint' label=system.power.label}}">{{system.power.labelAbbr}}</div>
      <div class="diff-label centre" data-tooltip="{{localize 'BRP.hpApHint' label=system.health.labelAbbr}}"
        style="grid-column: 10 / span 2;">{{system.health.labelAbbr}}</div>
      <div class="diff-label centre">{{ localize 'BRP.enc'}}</div>
      <div class="diff-label centre" data-tooltip="{{ localize 'BRP.ammoHint' }}">{{ localize 'BRP.ammo'}}</div>
      <div class="diff-label centre" data-tooltip="{{ localize 'BRP.status' }}">{{ localize 'BRP.statusShort'}}</div>
      <div class=" centre"  data-action="createDoc" data-document-class='Item' data-type='weapon' data-tooltip="{{ localize 'BRP.addWeapon'}}" >
        <a class="largeIcon"><i class="item-control fas fa-plus"></i></a>
      </div>
    </div>
    <ol class="gr-list">
      {{#each weapons as |weapon key|}}
        <li class="item weapon-tab-grid" data-item-id="{{weapon._id}}" data-skill-id="{{weapon.system.sourceID}}" data-document-class="Item" data-drag='true'>
          <div class="weapon-name rollable {{#if weapon.system.hasEffects}}italics bold{{/if}}"
            data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'TYPES.Item.weapon')}}"
            >{{weapon.name}}</div>
          <div class="font14 centre rollable weapon-name" data-action="weaponRoll" data-tooltip="{{weapon.system.skillName}}">{{weapon.system.skillScore}}</div>
          <div class="font14 {{#unless weapon.system.specialDmg}}rollable damage-name{{/unless}} centre" data-tooltip="{{weapon.system.damageHint}}" data-action="damageRoll">{{weapon.system.dmgName}}</div>
          <div class="font14 centre" data-tooltip="{{weapon.system.dbNameHint}}">{{weapon.system.dbName}}</div>
          <div class="font14 centre">{{weapon.system.rangeName}}</div>
          <div class="font14 centre" data-tooltip="{{localize 'BRP.rof'}} : {{weapon.system.rof}}">{{weapon.system.att}}</div>
          {{#if (eq weapon.type 'artillery')}}
            <div class="font14 centre">{{weapon.system.crew}}</div>
          {{else}}
            <div class="font14 centre">{{weapon.system.hands}}</div>
          {{/if}}
          {{#if (gt weapon.system.pSMax 0)}}
            <div class="combat-input-small"> <input class="centre inline-edit" data-field="pSCurr"
                name="weapon.system.pSCurr" type="number" value="{{weapon.system.pSCurr}}"/></div>
            <div class="hitloc-name centre">{{weapon.system.pSMax}}</div>
          {{else}}
            <div></div>
            <div></div>
          {{/if}}


          {{#if (gt weapon.system.hp 0)}}
            <div class="combat-input-small"> <input class="centre font14 inline-edit" data-field="hpCurr"
                name="weapon.system.hpCurr" type="number" value="{{weapon.system.hpCurr}}"/></div>
            <div class="font14 centre">{{weapon.system.hp}}</div>
          {{else}}
            <div></div>
            <div></div>
          {{/if}}
          <div class="font14 centre" data-tooltip="{{localize 'BRP.quantity'}} : {{weapon.system.quantity}}">
            {{weapon.system.actlEnc}}</div>
          {{#isOr (eq weapon.system.ammo null) (eq weapon.system.ammo 0)}}
            <div></div>
          {{else}}
            <div class="combat-input-small"> <input class="centre font14 inline-edit"
                data-tooltip="{{ localize 'BRP.ammoCap' }}: {{weapon.system.ammo}}" data-field="ammoCurr"
                name="weapon.system.ammoCurr" type="number" value="{{weapon.system.ammoCurr}}"/></div>
          {{/isOr}}
          <div class="font14 centre" data-action="itemToggle" data-property="equipStatus"
            data-tooltip="{{weapon.system.equippedName}}"><a class="mediumIcon">
              {{#if (eq weapon.system.equipStatus 'carried')}}<i class="fas fa-hand-holding"></i>{{/if}}
              {{#if (eq weapon.system.equipStatus 'packed')}}<i class="fas fa-treasure-chest"></i>{{/if}}
              {{#if (eq weapon.system.equipStatus 'stored')}}<i class="fas fa-warehouse"></i>{{/if}}
            </a>
          </div>
        </li>
      {{/each}}
    </ol>
    <br>

    {{#if useHPL}}
      <div class="hitloc-tab-grid">
        <div class="diff-label" style="grid-column: 1 / span 2;">{{ localize 'BRP.hitLoc'}}</div>
        <div class="diff-label centre">{{ localize 'BRP.hitLocRange'}}</div>
        <div></div>
        <div class="diff-label centre" data-tooltip="{{system.health.label}}">{{system.health.labelAbbr}}</div>
        <div></div>
        <div class="diff-label centre" data-tooltip="{{ localize 'BRP.apHint'}}">{{ localize 'BRP.ap'}}</div>
        <div class="diff-label centre">{{ localize 'BRP.status'}}</div>
        <div class="diff-label centre" data-tooltip="{{ localize 'BRP.woundHint' }}">{{ localize 'BRP.wounds'}}</div>
      </div>
      <ol class="gr-list">
      {{#each hitlocs as |hitloc key|}}
        <li class="item" style="list-style:none; margin: 0px;" data-item-id="{{hitloc._id}}" data-document-class="Item">
          <div class="hitloc-tab-grid">
            <div class="centre" data-action="addDamage" data-tooltip="{{ localize 'BRP.addWound' }}" data-item-id="{{hitloc._id}}"
              data-type="wound">
              <a class="mediumIcon"><i class="item-control fas fa-plus"></i></a>
            </div>
            <div class="font14 {{#unless (eq hitloc.system.lowRoll 0)}}hitloc-name rollable{{/unless}}"
              data-action="viewDoc" data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'TYPES.Item.hit-location')}}">{{hitloc.system.displayName}}</div>
            {{#if (eq hitloc.system.locType 'general')}}
              <div>&nbsp</div>
              <div>&nbsp</div>
              <div>&nbsp</div>
              <div>&nbsp</div>
              <div>&nbsp</div>
              <div>&nbsp</div>
            {{else}}
              {{#if (eq hitloc.system.lowRoll hitloc.system.highRoll)}}
               <div class="font14 centre">{{hitloc.system.lowRoll}}</div>
              {{else}}
               <div class="font14 centre">{{hitloc.system.lowRoll}} - {{hitloc.system.highRoll}}</div>
              {{/if}}
              <div class="font14 centre">{{hitloc.system.currHP}}</div>
              <div class="font14 centre">/</div>
              <div class="font14 centre">{{hitloc.system.maxHP}}</div>
              {{#if ../useAVRand}}
                <div class="font14 centre rollable" data-action="armourRoll" data-item-id="{{hitloc._id}}" data-property="ap"
                  data-tooltip="{{localize 'BRP.bap'}}: {{hitloc.system.avr2}}">{{hitloc.system.avr1}}</div>
              {{else}}
                <div class="font14 centre" data-tooltip="{{localize 'BRP.bap'}}: {{hitloc.system.av2}}">{{hitloc.system.av1}}</div>
              {{/if}}
              <div class="centre">
                {{#if hitloc.system.injured}} <a class="mediumIcon" data-tooltip="{{ localize 'BRP.injuredHPL' }}"><i
                    class="fas fa-face-head-bandage"></i></a> {{/if}}
                {{#if hitloc.system.bleeding}} <a class="mediumIcon" data-tooltip="{{ localize 'BRP.bleeding' }}"
                  data-action="itemToggle" data-property="bleeding"><i class="item-control fas fa-droplet"></i></a>
                {{/if}}
                {{#if hitloc.system.incapacitated}} <a class="mediumIcon" data-tooltip=" {{localize 'BRP.incapacitated' }}"
                  data-action="itemToggle"  data-property="incapacitated"><i
                    class="item-control fas fa-face-dizzy"></i></a> {{/if}}
                {{#if hitloc.system.dead}} <a class="mediumIcon" data-tooltip=" {{localize 'BRP.dead' }}"
                  data-action="itemToggle" data-property="dead"><i class="item-control fas fa-skull"></i></a> {{/if}}
                {{#if hitloc.system.severed}} <a class="mediumIcon" data-tooltip=" {{localize 'BRP.severed' }}"
                  data-action="itemToggle"  data-property="severed"><i class="item-control fas fa-bone-break"></i></a>
                {{/if}}
                {{#if hitloc.system.unconscious}} <a class="mediumIcon" data-tooltip=" {{localize 'BRP.unconscious' }}"
                  data-action="itemToggle"  data-property="unconscious"><i class="item-control fas fa-snooze"></i></a>
                {{/if}}
              </div>
            {{/if}}
            <div class="wound-name centre">
              {{#each ../wounds as |wound key|}}
                {{#if (eq wound.system.locId hitloc._id)}}
                <div
                  class="item rollable centre wound-item {{#unless wound.system.treated}}untreated{{/unless}}"
                  data-action="viewWound" data-wound-id="{{wound._id}}" data-item-id="{{hitloc._id}}" data-tooltip="{{localize 'BRP.viewWound'}}">
                  {{wound.system.value}}</div>
                {{/if}}
              {{/each}}
          </div>
        </div>
        </li>
      {{/each}}
      </ol>
    {{else}}
      <div class="diff-label">
        <span data-tooltip="{{ localize 'BRP.woundHint' }}">{{ localize 'BRP.wounds'}} (</span>
        <span class="centre " data-action="addDamage" data-tooltip="{{ localize 'BRP.addWound' }}" data-item-id="total" data-type="wound">
          <a><i class="item-control fas fa-plus"></i></a>
        </span>
        <span>)</span>
      </div>
      <div class="wound-name">
        {{#each wounds as |wound key|}}
          <li class="item" style="list-style: none;" data-item-id="{{wound._id}}" data-document-class="Item">
          <div class="wound-grid">
            <div class="rollable centre wound-item {{#unless wound.system.treated}}untreated{{/unless}}" data-action="viewDoc"
              data-tooltip="{{localize 'BRP.viewDoc' type=(localize 'TYPES.Item.wound')}}">{{wound.system.value}}</div>
            <div class="centre rollable"><a data-action="treatWound" data-healing="medical" data-tooltip="{{localize 'BRP.treatWound'}}"><i
                  class="fas fa-kit-medical"></i></a></div>
            <div class="centre rollable"><a data-action="treatWound" data-healing="magic" data-tooltip="{{localize 'BRP.castHealing'}}"><i
                  class="fas fa-hand-sparkles"></i></a></div>
            <div></div>
          </div>
          </li>
        {{/each}}
      </div>
    {{/if}}
  </section>
  {{#unless useHPL}}
    <div class="combat-attributes">
      <div class="bold">{{ localize 'BRP.majorWound'}}</div>
      <div>{{system.health.mjrwnd}}</div>
      <div class="bold">{{ localize 'BRP.ap'}}</div>
      {{#if useAVRand}}
        <div class="rollable" data-action="armourRoll" data-property="ap">{{system.avr1}}</div>
      {{else}}
        <div>{{system.av1}}</div>
      {{/if}}
      <div class="bold">{{ localize 'BRP.bap'}}</div>
      {{#if useAVRand}}
        <div class="rollable" data-action="armourRoll" data-property="ap">{{system.avr2}}</div>
      {{else}}
        <div>{{system.av2}}</div>
      {{/if}}
    </div>
    <br>
  {{/unless}}
  <br>
  <div class="diff-label">{{localize 'BRP.healing'}}
    <span class="centre rollable" style="padding-left: 30px;"><a class="largeIcon" data-action="healing" data-prop="natural" data-tooltip="{{localize 'BRP.naturalHealing'}}"><i
      class="fas fa-clock"></i></a></span>
    <span class="centre rollable" style="padding-left: 30px;"><a class="largeIcon" data-action="healing" data-prop="all" data-tooltip="{{localize 'BRP.allHeal'}}"><i
      class="fas fa-staff-snake"></i></a></span>
    {{#unless useHPL}}
      <span class="centre rollable" style="padding-left: 30px;"><a class="largeIcon" data-action="healing" data-prop="reset" data-tooltip="{{localize 'BRP.resetDaily'}}"><i
        class="fas fa-sunrise"></i></a></span>
    {{/unless}}
  </div>
  <br>
</section>