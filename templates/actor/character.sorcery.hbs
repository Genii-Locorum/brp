<section class="actor tab sorcery {{tab.cssClass}}" data-group="primary" data-tab="sorcery">
    <div class="sorcery-listitem">
      <div class="diff-label">{{sorceryLabel}}</div>
      <div class="diff-label centre">{{ localize 'BRP.range'}}</div>
      <div class="diff-label centre" data-tooltip="{{localize 'BRP.spellLvlHint'}}">{{ localize 'BRP.level'}}</div>
      <div class="diff-label centre" data-tooltip="{{localize 'BRP.ppCostHint' label=system.power.labelAbbr}}">{{system.power.labelAbbr}}</div>
      <div class="diff-label centre" data-tooltip="{{ localize 'BRP.spellCost' }}">{{ localize 'BRP.powCost'}}</div>
      <div class="diff-label centre" data-tooltip="{{ localize 'BRP.memHint' }}">{{ localize 'BRP.mem'}}</div>
      <div class="diff-label centre" data-action="createDoc" data-tooltip="{{ localize 'BRP.addItem' type=sorceryLabel }}" data-type="sorcery" data-document-class="Item">
        <a class="largeIcon"><i class="item-control fas fa-plus"></i></a>
      </div>
    </div>
    <ol class="gr-list">
      {{#each sorceries as |sorcery id|}}
        <li class="item sorcery-listitem" data-item-id="{{sorcery._id}}" data-document-class="Item">
          <div class="rollable" data-action="viewDoc"
              data-tooltip="{{localize 'BRP.viewSpell' type=../sorceryLabel }}">{{sorcery.name}}</div>
          <div class="centre">{{sorcery.system.range}}</div>
          <div class="centre">{{sorcery.system.currLvl}}{{#if sorcery.system.var}}({{sorcery.system.memLvl}}){{/if}}</div>
          <div class="centre">{{sorcery.system.ppCost}}</div>
          <div class="centre">{{sorcery.system.powCost}}</div>
          <div class="centre"><a class="mediumIcon" data-action="itemToggle" data-property="mem"><i class="{{#if sorcery.system.mem}}fa-solid fa-book-open-cover{{else}}fa-light fa-book-open-cover{{/if}}"></i></a></div>
        </li>
      {{/each}}
    </ol>
</section>