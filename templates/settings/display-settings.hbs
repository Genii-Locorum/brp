  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.charSheetTitleFontSize'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="charSheetTitleFontSize" type="text" value="{{optSet.charSheetTitleFontSize.value}}" data-dtype="Number" />
    </div>
