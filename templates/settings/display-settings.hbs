<div class="brp settingsForm flexcol" autocomplete="off">
  <h2 class="bold">{{localize 'BRP.Settings.displayOptions'}}</h2>


  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.actorFontColour'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="actorFontColour" type="text" value="{{optSet.actorFontColour.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.actorFontColourHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.actorTitleColour'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="actorTitleColour" type="text" value="{{optSet.actorTitleColour.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.actorTitleColourHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.actorTertiaryColour'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="actorTertiaryColour" type="text" value="{{optSet.actorTertiaryColour.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.actorTertiaryColourHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.brpIconPrimary'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="brpIconPrimary" type="text" value="{{optSet.brpIconPrimary.value}}" />
