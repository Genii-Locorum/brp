    <label class="bold">{{localize 'BRP.Settings.actorTabNameColour'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="actorTabNameColour" type="text" value="{{optSet.actorTabNameColour.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.actorTabNameColourHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.actorRollableColour'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="actorRollableColour" type="text" value="{{optSet.actorRollableColour.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.actorRollableColourHint'}}</p>
