    <div class="form-fields" style="flex: 1;">
      <file-picker name="actorSheetBackground" type="pictures" value="{{optSet.actorSheetBackground.value}}"></file-picker>
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.actorSheetBackgroundHint'}}</p>
