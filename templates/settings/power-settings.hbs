<div class="brp settingsForm flexcol" autocomplete="off">
  <h2 class="bold">{{localize 'BRP.Settings.powerRules'}}</h2>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useMagic'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.magic.value}} name="magic">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useMagicHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.magicLabel'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="magicLabel" type="text" value="{{optSet.magicLabel.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.magicLabelHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useMutation'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.mutation.value}} name="mutation">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useMutationHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.mutationLabel'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="mutationLabel" type="text" value="{{optSet.mutationLabel.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.mutationLabelHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.usePsychic'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.psychic.value}} name="psychic">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.usePsychicHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.psychicLabel'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="psychicLabel" type="text" value="{{optSet.psychicLabel.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.psychicLabelHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useSorcery'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.sorcery.value}} name="sorcery">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useSorceryHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.sorceryLabel'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="sorceryLabel" type="text" value="{{optSet.sorceryLabel.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.sorceryLabelHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useSuper'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.super.value}} name="super">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useSuperHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.superLabel'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="superLabel" type="text" value="{{optSet.superLabel.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.superLabelHint'}}</p>
  </div>

  <br>
</div>