    <label class="bold">{{localize 'BRP.Settings.hpLabelLong'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input class="centre" name="hpLabelLong" type="text" value="{{optSet.hpLabelLong.value}}" />
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.hpLabelLongHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.hpLabelShort'}}</label>
