<brp class="brp settingsForm flexcol" autocomplete="off">
  <h2 class="bold">{{localize 'BRP.Settings.optionalRules'}}</h2>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useHPL'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.useHPL.value}} name="useHPL">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useHPLHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useEDU'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.useEDU.value}} name="useEDU">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useEDUHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useSAN'}}</label>
    <div class="form-fields" style="flex: 1;">
      <input type="checkbox" {{checked optSet.useSAN.value}} name="useSAN">
    </div>
    <p class="settingNote">{{localize 'BRP.Settings.useSANHint'}}</p>
  </div>

  <div class="form-group">
    <label class="bold">{{localize 'BRP.Settings.useFP'}}</label>
